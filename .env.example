# ─── App ────────────────────────────────────────────────────────────────
APP_NAME="Market Radar"
DEBUG=true
DEMO_MODE=true

# ─── Database ────────────────────────────────────────────────────────────
# Local (non-Docker): SQLite, zero setup required
DATABASE_URL=sqlite:///./market_radar.db
# Docker / PostgreSQL: uncomment and set below
# DATABASE_URL=postgresql://marketradar:marketradar@localhost:5432/marketradar

# ─── Optional API Integrations ───────────────────────────────────────────
# Leave empty to stay in demo mode. Set DEMO_MODE=false to activate live data.

# Stocks: Alpha Vantage (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_KEY=

# Crypto: CoinGecko Pro (https://www.coingecko.com/api/documentation)
COINGECKO_API_KEY=

# Polymarket (https://docs.polymarket.com)
POLYMARKET_API_KEY=

# Social: Twitter/X Bearer Token
TWITTER_BEARER_TOKEN=

# Social: Reddit (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Scoring Parameters ──────────────────────────────────────────────────
SCORING_HORIZON_DAYS=5
MIN_MARKET_CAP_STOCKS=1000000000
MIN_LIQUIDITY_MEMECOINS=1000000
STOCK_UNIVERSE_SIZE=100
MEMECOIN_UNIVERSE_SIZE=50
POLYMARKET_WEIGHT=0.10
