# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="Market Radar"
DEBUG=true
DEMO_MODE=true

# ─── Database ─────────────────────────────────────────────────────────────────
# Local (non-Docker): SQLite, zero setup required
DATABASE_URL=sqlite:///./market_radar.db
# Docker / PostgreSQL: uncomment and set below
# DATABASE_URL=postgresql://marketradar:marketradar@localhost:5432/marketradar

# ─── Provider Priority ────────────────────────────────────────────────────────
# The app works fully in demo mode with no keys configured.
# When keys are set, set the corresponding *_ENABLED=true to activate live data.
#
#   Stocks:      FMP → Alpha Vantage → Twelve Data → demo
#   Crypto:      CoinGecko → demo
#   Prediction:  Polymarket → Kalshi → demo
#   News:        NewsAPI → demo
#   Social:      (deferred — not yet integrated)

# ─── Stocks: Financial Modeling Prep (primary) ───────────────────────────────
# Sign up: https://site.financialmodelingprep.com/developer/docs/
# Free tier: 250 req/day  |  Paid plans start at $14/mo
FMP_ENABLED=false
FMP_API_KEY=

# ─── Stocks: Alpha Vantage (fallback) ────────────────────────────────────────
# Sign up: https://www.alphavantage.co/support/#api-key
# Free tier: 25 req/day, 500 req/mo
ALPHA_VANTAGE_ENABLED=false
ALPHA_VANTAGE_KEY=

# ─── Stocks: Twelve Data (2nd fallback) ──────────────────────────────────────
# Sign up: https://twelvedata.com/docs
# Free tier: 800 req/day
TWELVE_DATA_ENABLED=false
TWELVE_DATA_KEY=

# ─── Crypto: CoinGecko (primary) ─────────────────────────────────────────────
# Sign up: https://www.coingecko.com/api/documentation
# Free tier available; Pro plan unlocks higher rate limits
COINGECKO_ENABLED=false
COINGECKO_API_KEY=

# ─── Prediction Markets: Polymarket (primary) ────────────────────────────────
# Sign up: https://docs.polymarket.com
# Public CLOB API; key may not be required for read-only use
POLYMARKET_ENABLED=false
POLYMARKET_API_KEY=

# ─── Prediction Markets: Kalshi (fallback) ───────────────────────────────────
# Sign up: https://kalshi.com/docs/api
# Requires RSA key pair authentication:
#   Step 1: Create account at kalshi.com (demo: demo.kalshi.co)
#   Step 2: Generate RSA key pair:
#             openssl genrsa -out kalshi_private.pem 2048
#             openssl rsa -in kalshi_private.pem -pubout -out kalshi_public.pem
#   Step 3: Upload public key at kalshi.com/profile → API Keys
#   Step 4: Set key ID and private key below (never commit the private key)
KALSHI_ENABLED=false
KALSHI_ENV=demo                         # "demo" | "production"
KALSHI_API_KEY_ID=                      # Key ID from Kalshi dashboard
KALSHI_PRIVATE_KEY_PATH=                # Path to PEM file (preferred for local dev)
KALSHI_PRIVATE_KEY_PEM=                 # Or inline PEM (use \n for newlines in .env)
KALSHI_TIMEOUT_SECONDS=10

# ─── News: NewsAPI (primary) ─────────────────────────────────────────────────
# Sign up: https://newsapi.org/register
# Free tier: 100 req/day (developer plan)
NEWSAPI_ENABLED=false
NEWSAPI_KEY=

# ─── Social: Twitter / X (deferred — not yet integrated) ─────────────────────
TWITTER_ENABLED=false
TWITTER_BEARER_TOKEN=

# ─── Social: Reddit (deferred — not yet integrated) ──────────────────────────
REDDIT_ENABLED=false
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ─── Scoring Parameters ───────────────────────────────────────────────────────
SCORING_HORIZON_DAYS=5
MIN_MARKET_CAP_STOCKS=1000000000
MIN_LIQUIDITY_MEMECOINS=1000000
STOCK_UNIVERSE_SIZE=100
MEMECOIN_UNIVERSE_SIZE=50
POLYMARKET_WEIGHT=0.10
